{
    "manifest_version": 3,
    "name": "Privacy Policy Analyzer",
    "version": "1.0.4",
    "description": "",
    "icons": {
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "privacy-analyzer@agreesmarter.local",
            "strict_min_version": "120.0"
        }
    },
    "action": {
        "default_popup": "src/popup.html"
    },
    "background": {
        "service_worker": "src/background.js",
        "scripts": [
            "src/background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content_script.js"
            ],
            "run_at": "document_idle",
            "css": [
                "src/content_script.css"
            ]
        }
    ],
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "scripting",
        "webRequest"
    ],
    "host_permissions": [
        "<all_urls>"
    ]
    // "data_collection_permissions": []
}